# =========================
# TYXT core backend
# =========================
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
MODEL_NAME=deepseek-r1:8b

# Cloud API (when LLM_PROVIDER=newapi)
NEWAPI_BASE_URL=
NEWAPI_API_KEY=
NEWAPI_MODEL=
NEWAPI_RETRY_TIMES=2
NEWAPI_RETRY_BACKOFF_S=0.8
NEWAPI_STREAM_READ_TIMEOUT_S=30

# Flask session
FLASK_SECRET_KEY=change-me-please
SESSION_COOKIE_SAMESITE=Lax

# Paths (default values are relative to project root)
TYXT_CHROMA_DIR=./memory_db
TYXT_CHROMA_COLLECTION=tyxt_memory
TYXT_CHROMA_FALLBACK_COLLECTION=tyxt_misc
TYXT_PROFILE_DIR=./profiles
TYXT_WAREHOUSE_DIR=./memory_warehouse
TYXT_UI_HTML=./frontend/TYXT_UI.html
TYXT_FRONTEND_DIR=./frontend
CONFIG_FILE=./config.json

# Optional HTTPS certs
TYXT_SSL_CERT_FILE=
TYXT_SSL_KEY_FILE=

# Generation params
GEN_MAX_TOKENS=2048
GEN_TEMP=1.0
GEN_TOP_P=0.95
GEN_TOP_K=60
NUM_CTX=4096
MAX_REQUEST_SECONDS=600

# Context and streaming
TYXT_CONTEXT_TURN_LIMIT=20
TYXT_WINDOW_DISPLAY_TURN_LIMIT=60
TYXT_CHAT_STREAM_ENABLED=1

# Embedding / memory retrieval
EMBED_PROVIDER=ollama
MEM_EMBED_MODEL=bge-m3
EMBED_TIMEOUT_S=60
EMBED_DIM_DEFAULT=1024
MEM_TOPK=20
MEM_LIGHT_TOPK=10
MEM_LOOKBACK_DAYS=365
IMPORTANCE_MAX=10.0

# Feature toggles
TYXT_ENABLE_PROFILE_UPDATE=1
TYXT_ENABLE_MEMORY_STRIP_AUTO=1
DEFER_POST_REPLY_TASKS_FOR_NAPCAT=1

# TYXT Skills runtime gates
TYXT_SKILLS_ALLOW_NETWORK=1
TYXT_SKILLS_ALLOW_FILESYSTEM=1
TYXT_SKILLS_ALLOW_LLM=0

# MCP Bridge (Phase X PoC)
TYXT_MCP_ENABLED=0
TYXT_MCP_CONFIG_PATH=./configs/mcp_servers.json

# Assistant display name
ASSISTANT_NAME=

# =========================
# Multimodal / TTS
# =========================
ALLOWED_DIR=./Ollama_agent_shared
SOVITS_TTS_URL=http://127.0.0.1:9880/tts
SOVITS_REF_AUDIO_DIR=./Ollama_agent_shared/refs
SOVITS_TEXT_SPLIT_METHOD=cut0
SOVITS_AUTO_VOICE=1
SOVITS_MIN_SEGMENT_CHARS=8

TTS_OUTPUT_DIR=./Ollama_agent_shared/tts
TESSERACT_PATH=
OCR_LANG=chi_sim+eng

# =========================
# NapCat bridge (optional)
# =========================
BACKEND_CHAT=http://127.0.0.1:5000/chat
BACKEND_BASE_URL=http://127.0.0.1:5000
BACKEND_TTS_URL=http://127.0.0.1:5000/tools/tts
BACKEND_CONNECT_TIMEOUT_S=8
BACKEND_TIMEOUT_S=600

REVERSE_WS_HOST=127.0.0.1
REVERSE_WS_PORT=6199
REVERSE_WS_PATH=/ws

OWNER_QQ=
BOT_NAME_KEYWORDS=AI,Assistant
PRIVATE_SEND_MODE=string
PRIVATE_SEND_AUTO_ESCAPE=true
PRIVATE_LEGACY_SEND_PRIVATE=true

QQ_TTS_ENABLE=true
QQ_TTS_PRIVATE_ONLY=true
QQ_TTS_VOICE_ID=default
QQ_TTS_MAX_CHARS=120
QQ_TTS_MAX_SEGMENTS=6
QQ_TTS_MIN_SEGMENT_CHARS=12
QQ_TTS_TIMEOUT_S=90
QQ_TTS_SEND_ORDER=text_first
QQ_TTS_MERGE_SEGMENTS=true
QQ_TTS_LOCK_VOICE_PER_TURN=true
QQ_TTS_TEXT_FIRST_ASYNC=true
QQ_TTS_TEXT_FIRST_ASYNC_DELAY_S=0.05
NAPCAT_TMP_IMAGE_DIR=./Ollama_agent_shared/uploads/napcat_tmp

# OCR / image understanding
GEMINI_API_KEY=
GEMINI_OCR_ENABLED=true
GEMINI_OCR_ENDPOINT=
GEMINI_OCR_MODEL=
GEMINI_OCR_TIMEOUT_SEC=60

# Debug
DEBUG=false
