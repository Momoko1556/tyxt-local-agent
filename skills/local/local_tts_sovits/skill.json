{
  "id": "local_tts_sovits",
  "name": "本地 TTS 朗读（GPT-SoVITS）",
  "version": "0.1.0",
  "author": "TYXT",
  "description": "调用本地 GPT-SoVITS 引擎，将文本转换为语音文件。",
  "entry": {
    "type": "python",
    "module": "handler",
    "function": "run"
  },
  "inputs": {
    "type": "object",
    "required": [
      "text"
    ],
    "properties": {
      "text": {
        "type": "string",
        "description": "需要朗读的文本内容。"
      },
      "voice_id": {
        "type": "string",
        "description": "可选的声音预设 ID，默认为 default。",
        "default": "default"
      }
    }
  },
  "outputs": {
    "type": "object",
    "properties": {
      "ok": {
        "type": "boolean"
      },
      "data": {
        "type": "object",
        "properties": {
          "rel_path": {
            "type": "string"
          },
          "voice_id": {
            "type": "string"
          }
        }
      },
      "error": {
        "type": "string"
      }
    }
  },
  "permissions": {
    "network": false,
    "filesystem": true,
    "llm": false
  },
  "tags": [
    "tts",
    "audio",
    "local"
  ],
  "unsafe": false
}

